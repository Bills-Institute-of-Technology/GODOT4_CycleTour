## .gitignore for Godot 4 + C# (.NET) project
## Combines Godot 4, .NET, and AI tooling ignores.
##
## .NET base: https://github.com/github/gitignore/blob/main/Dotnet.gitignore
## Godot base: https://github.com/github/gitignore/blob/main/Godot.gitignore

# -----------------------------------------------------------------------
# Godot 4 — Engine-generated cache and import data
# -----------------------------------------------------------------------
# Godot 4 local cache directory (fully regenerated on project open)
.godot/

# Godot 3 legacy import directory (not used in Godot 4, but safe to keep)
.import/

# Compiled GDNative/GDExtension libraries
*.so
*.dylib
*.dll.meta

# Exported project builds
export.cfg
export_presets.cfg

# Imported/compiled translation files (auto-generated from CSVs)
*.translation

# -----------------------------------------------------------------------
# Godot 4 + C# / Mono
# -----------------------------------------------------------------------
# Mono crash logs
mono_crash.*.json

# Godot Mono/C# generated data directories
.mono/
data_*/

# -----------------------------------------------------------------------
# AI Tooling
# -----------------------------------------------------------------------
# Windsurf AI local state (not project artifacts)
.windsurf/.cache/

# -----------------------------------------------------------------------
# .NET (original content below)
# -----------------------------------------------------------------------

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# dotenv environment variables file
.env

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml
